+static gboolean
+should_round_window (MetaWindowActor *window_actor)
+{
+  MetaWindow *window = meta_window_actor_get_meta_window (window_actor);
+
+  if (!window || !meta_window_config_is_floating (window->config))
+    return FALSE;
+
+  switch (meta_window_get_window_type (window))
+    {
+    case META_WINDOW_NORMAL:
+    case META_WINDOW_DIALOG:
+    case META_WINDOW_MODAL_DIALOG:
+    case META_WINDOW_UTILITY:
+      return TRUE;
+
+    default:
+      return FALSE;
+    }
+}
+
+static void
+sync_rounded_clip (MetaWindowActorWayland *self)
+{
+  MetaWindowActor *window_actor = META_WINDOW_ACTOR (self);
+  MetaWindow *window = meta_window_actor_get_meta_window (window_actor);
+  ClutterActor *surface_container = CLUTTER_ACTOR (self->surface_container);
+  gboolean enabled = should_round_window (window_actor);
+  int geometry_scale = meta_window_actor_get_geometry_scale (window_actor);
+  MtkRectangle buffer_rect;
+
+  meta_window_get_buffer_rect (window, &buffer_rect);
+  clutter_actor_set_size (surface_container,
+                          buffer_rect.width / geometry_scale,
+                          buffer_rect.height / geometry_scale);
+
+  if (enabled)
+    {
+      MtkRectangle frame_rect;
+      graphene_rect_t clip_bounds;
+
+      meta_window_get_frame_rect (window, &frame_rect);
+      graphene_rect_init (&clip_bounds,
+                          (frame_rect.x - buffer_rect.x) / geometry_scale,
+                          (frame_rect.y - buffer_rect.y) / geometry_scale,
+                          frame_rect.width / geometry_scale,
+                          frame_rect.height / geometry_scale);
+      meta_rounded_clip_effect_set_bounds (self->rounded_clip_effect,
+                                           &clip_bounds,
+                                           ROUNDED_CORNER_RADIUS);
+    }
+
+  if (clutter_actor_meta_get_enabled (
+        CLUTTER_ACTOR_META (self->rounded_clip_effect)) != enabled)
+    {
+      clutter_actor_meta_set_enabled (
+        CLUTTER_ACTOR_META (self->rounded_clip_effect), enabled);
+    }
+
+  clutter_actor_set_clip_to_allocation (surface_container, enabled);
+}
+
+static void
+ensure_shadow_pipeline (MetaWindowActorWayland *self,
+                        CoglFramebuffer        *framebuffer)
+{
+  CoglSnippet *snippet;
+
+  if (self->shadow_pipeline)
+    return;
+
+  self->shadow_pipeline =
+    cogl_pipeline_new (cogl_framebuffer_get_context (framebuffer));
+  cogl_pipeline_set_layer_null_texture (self->shadow_pipeline, 0);
+  cogl_pipeline_set_blend (
+    self->shadow_pipeline,
+    "RGBA = ADD (SRC_COLOR, DST_COLOR * (1 - SRC_COLOR[A]))",
+    NULL);
+
+  snippet = cogl_snippet_new (COGL_SNIPPET_HOOK_FRAGMENT,
+                              ADWAITA_SHADOW_FRAGMENT_SHADER_DECLARATIONS,
+                              ADWAITA_SHADOW_FRAGMENT_SHADER_CODE);
+  cogl_pipeline_add_snippet (self->shadow_pipeline, snippet);
+  g_object_unref (snippet);
+}
+
+static void
+paint_adwaita_shadow (MetaWindowActorWayland *self,
+                      ClutterPaintContext    *paint_context)
+{
+  MetaWindowActor *window_actor = META_WINDOW_ACTOR (self);
+  MetaWindow *window = meta_window_actor_get_meta_window (window_actor);
+  ClutterActor *actor = CLUTTER_ACTOR (self);
+  CoglFramebuffer *framebuffer;
+  MtkRectangle frame_rect;
+  MtkRectangle buffer_rect;
+  int geometry_scale;
+  float frame_size[2];
+  float extent;
+  float x;
+  float y;
+  float actor_opacity;
+
+  if (!should_round_window (window_actor))
+    return;
+
+  framebuffer = clutter_paint_context_get_framebuffer (paint_context);
+  ensure_shadow_pipeline (self, framebuffer);
+
+  meta_window_get_frame_rect (window, &frame_rect);
+  meta_window_get_buffer_rect (window, &buffer_rect);
+  geometry_scale = meta_window_actor_get_geometry_scale (window_actor);
+  extent = ADWAITA_SHADOW_EXTENT * geometry_scale;
+  x = frame_rect.x - buffer_rect.x;
+  y = frame_rect.y - buffer_rect.y;
+  frame_size[0] = frame_rect.width;
+  frame_size[1] = frame_rect.height;
+  actor_opacity =
+    (clutter_actor_get_paint_opacity (actor) / 255.0f) *
+    (window->opacity / 255.0f);
+
+  cogl_pipeline_set_uniform_float (
+    self->shadow_pipeline,
+    cogl_pipeline_get_uniform_location (self->shadow_pipeline, "frame_size"),
+    2, 1, frame_size);
+  cogl_pipeline_set_uniform_1f (
+    self->shadow_pipeline,
+    cogl_pipeline_get_uniform_location (self->shadow_pipeline,
+                                        "corner_radius"),
+    ROUNDED_CORNER_RADIUS * geometry_scale);
+  cogl_pipeline_set_uniform_1f (
+    self->shadow_pipeline,
+    cogl_pipeline_get_uniform_location (self->shadow_pipeline,
+                                        "geometry_scale"),
+    geometry_scale);
+  cogl_pipeline_set_uniform_1f (
+    self->shadow_pipeline,
+    cogl_pipeline_get_uniform_location (self->shadow_pipeline, "focused"),
+    meta_window_appears_focused (window) ? 1.0f : 0.0f);
+  cogl_pipeline_set_uniform_1f (
+    self->shadow_pipeline,
+    cogl_pipeline_get_uniform_location (self->shadow_pipeline,
+                                        "actor_opacity"),
+    actor_opacity);
+
+  cogl_framebuffer_draw_textured_rectangle (
+    framebuffer,
+    self->shadow_pipeline,
+    x - extent,
+    y - extent,
+    x + frame_rect.width + extent,
+    y + frame_rect.height + extent,
+    0.0f, 0.0f, 1.0f, 1.0f);
+}
+
+static void
+meta_window_actor_wayland_paint (ClutterActor        *actor,
+                                 ClutterPaintContext *paint_context)
+{
+  paint_adwaita_shadow (META_WINDOW_ACTOR_WAYLAND (actor), paint_context);
+
+  CLUTTER_ACTOR_CLASS (meta_window_actor_wayland_parent_class)->paint (
+    actor, paint_context);
+}
+
+static gboolean
+meta_window_actor_wayland_get_paint_volume (ClutterActor       *actor,
+                                            ClutterPaintVolume *volume)
+{
+  MetaWindowActorWayland *self = META_WINDOW_ACTOR_WAYLAND (actor);
+  MetaWindowActor *window_actor = META_WINDOW_ACTOR (self);
+  ClutterActorClass *parent_class =
+    CLUTTER_ACTOR_CLASS (meta_window_actor_wayland_parent_class);
+
+  if (!parent_class->get_paint_volume (actor, volume))
+    return FALSE;
+
+  if (should_round_window (window_actor))
+    {
+      MetaWindow *window = meta_window_actor_get_meta_window (window_actor);
+      MtkRectangle frame_rect;
+      MtkRectangle buffer_rect;
+      int geometry_scale = meta_window_actor_get_geometry_scale (window_actor);
+      float extent = ADWAITA_SHADOW_EXTENT * geometry_scale;
+      ClutterActorBox shadow_box;
+
+      meta_window_get_frame_rect (window, &frame_rect);
+      meta_window_get_buffer_rect (window, &buffer_rect);
+      shadow_box.x1 = frame_rect.x - buffer_rect.x - extent;
+      shadow_box.y1 = frame_rect.y - buffer_rect.y - extent;
+      shadow_box.x2 = shadow_box.x1 + frame_rect.width + 2 * extent;
+      shadow_box.y2 = shadow_box.y1 + frame_rect.height + 2 * extent;
+      clutter_paint_volume_union_box (volume, &shadow_box);
+    }
+
+  return TRUE;
+}
