+#define ROUNDED_CORNER_RADIUS 15.0f
+#define ADWAITA_SHADOW_EXTENT 19.0f
+
+#define ROUNDED_CLIP_FRAGMENT_SHADER_DECLARATIONS                         \
+"uniform vec4 bounds;           // x, y: top left; z, w: bottom right  \n"\
+"uniform float clip_radius;                                            \n"\
+"uniform vec2 pixel_step;                                              \n"\
+"                                                                      \n"\
+"float                                                                 \n"\
+"rounded_rect_coverage (vec2 p)                                        \n"\
+"{                                                                     \n"\
+"  vec2 center = (bounds.xy + bounds.zw) * 0.5;                        \n"\
+"  vec2 half_size = (bounds.zw - bounds.xy) * 0.5;                     \n"\
+"  vec2 q = abs (p - center) - (half_size - vec2 (clip_radius));      \n"\
+"  float distance = length (max (q, vec2 (0.0))) +                    \n"\
+"                   min (max (q.x, q.y), 0.0) - clip_radius;          \n"\
+"                                                                      \n"\
+"  return 1.0 - smoothstep (-0.5, 0.5, distance);                      \n"\
+"}                                                                     \n"
+
+#define ROUNDED_CLIP_FRAGMENT_SHADER_CODE                               \
+"vec2 texture_coord = cogl_tex_coord0_in.xy / pixel_step;             \n"\
+"cogl_color_out *= rounded_rect_coverage (texture_coord);              \n"
+
+typedef struct _MetaRoundedClipEffect
+{
+  ClutterOffscreenEffect parent;
+
+  ClutterActor *actor;
+  graphene_rect_t bounds;
+  float radius;
+} MetaRoundedClipEffect;
+
+typedef ClutterOffscreenEffectClass MetaRoundedClipEffectClass;
+
+G_DEFINE_TYPE (MetaRoundedClipEffect,
+               meta_rounded_clip_effect,
+               CLUTTER_TYPE_OFFSCREEN_EFFECT)
+
+static CoglPipeline *
+meta_rounded_clip_effect_create_pipeline (ClutterOffscreenEffect *effect,
+                                          CoglTexture            *texture)
+{
+  ClutterOffscreenEffectClass *parent_class =
+    CLUTTER_OFFSCREEN_EFFECT_CLASS (meta_rounded_clip_effect_parent_class);
+  CoglPipeline *pipeline;
+  CoglSnippet *snippet;
+
+  pipeline = parent_class->create_pipeline (effect, texture);
+  snippet = cogl_snippet_new (COGL_SNIPPET_HOOK_FRAGMENT,
+                              ROUNDED_CLIP_FRAGMENT_SHADER_DECLARATIONS,
+                              ROUNDED_CLIP_FRAGMENT_SHADER_CODE);
+  cogl_pipeline_add_snippet (pipeline, snippet);
+  g_object_unref (snippet);
+
+  return pipeline;
+}
+
+static void
+meta_rounded_clip_effect_paint_target (ClutterOffscreenEffect *effect,
+                                       ClutterPaintNode       *node,
+                                       ClutterPaintContext    *paint_context)
+{
+  MetaRoundedClipEffect *self = (MetaRoundedClipEffect *) effect;
+  ClutterOffscreenEffectClass *parent_class =
+    CLUTTER_OFFSCREEN_EFFECT_CLASS (meta_rounded_clip_effect_parent_class);
+  CoglPipeline *pipeline = clutter_offscreen_effect_get_pipeline (effect);
+  CoglTexture *texture = clutter_offscreen_effect_get_texture (effect);
+  float actor_width, actor_height;
+  float texture_width, texture_height;
+  float scale_x, scale_y;
+  float shader_bounds[4];
+  float pixel_step[2];
+
+  clutter_actor_get_size (self->actor, &actor_width, &actor_height);
+  texture_width = cogl_texture_get_width (texture);
+  texture_height = cogl_texture_get_height (texture);
+
+  if (actor_width <= 0.0f || actor_height <= 0.0f)
+    return;
+
+  scale_x = texture_width / actor_width;
+  scale_y = texture_height / actor_height;
+  shader_bounds[0] = self->bounds.origin.x * scale_x;
+  shader_bounds[1] = self->bounds.origin.y * scale_y;
+  shader_bounds[2] = (self->bounds.origin.x + self->bounds.size.width) * scale_x;
+  shader_bounds[3] = (self->bounds.origin.y + self->bounds.size.height) * scale_y;
+  pixel_step[0] = 1.0f / texture_width;
+  pixel_step[1] = 1.0f / texture_height;
+
+  cogl_pipeline_set_uniform_float (
+    pipeline,
+    cogl_pipeline_get_uniform_location (pipeline, "bounds"),
+    4, 1, shader_bounds);
+  cogl_pipeline_set_uniform_1f (
+    pipeline,
+    cogl_pipeline_get_uniform_location (pipeline, "clip_radius"),
+    self->radius * MIN (scale_x, scale_y));
+  cogl_pipeline_set_uniform_float (
+    pipeline,
+    cogl_pipeline_get_uniform_location (pipeline, "pixel_step"),
+    2, 1, pixel_step);
+
+  parent_class->paint_target (effect, node, paint_context);
+}
+
+static void
+meta_rounded_clip_effect_set_actor (ClutterActorMeta *meta,
+                                    ClutterActor     *actor)
+{
+  MetaRoundedClipEffect *self = (MetaRoundedClipEffect *) meta;
+  ClutterActorMetaClass *parent_class =
+    CLUTTER_ACTOR_META_CLASS (meta_rounded_clip_effect_parent_class);
+
+  parent_class->set_actor (meta, actor);
+  self->actor = actor;
+}
+
+static void
+meta_rounded_clip_effect_class_init (MetaRoundedClipEffectClass *klass)
+{
+  ClutterActorMetaClass *actor_meta_class = CLUTTER_ACTOR_META_CLASS (klass);
+  ClutterOffscreenEffectClass *offscreen_effect_class =
+    CLUTTER_OFFSCREEN_EFFECT_CLASS (klass);
+
+  actor_meta_class->set_actor = meta_rounded_clip_effect_set_actor;
+  offscreen_effect_class->create_pipeline =
+    meta_rounded_clip_effect_create_pipeline;
+  offscreen_effect_class->paint_target =
+    meta_rounded_clip_effect_paint_target;
+}
