+}
+
+static void
+meta_rounded_clip_effect_set_bounds (MetaRoundedClipEffect  *self,
+                                     const graphene_rect_t  *bounds,
+                                     float                   radius)
+{
+  if (graphene_rect_equal (&self->bounds, bounds) &&
+      G_APPROX_VALUE (self->radius, radius, FLT_EPSILON))
+    return;
+
+  graphene_rect_init_from_rect (&self->bounds, bounds);
+  self->radius = radius;
+  clutter_effect_queue_repaint (CLUTTER_EFFECT (self));
+}
+
+#define ADWAITA_SHADOW_FRAGMENT_SHADER_DECLARATIONS                     \
+"uniform vec2 frame_size;                                              \n"\
+"uniform float corner_radius;                                          \n"\
+"uniform float geometry_scale;                                         \n"\
+"uniform float focused;                                                \n"\
+"uniform float actor_opacity;                                          \n"\
+"                                                                      \n"\
+"float rounded_rect_distance (vec2 p, float radius, float spread)      \n"\
+"{                                                                     \n"\
+"  vec2 half_size = frame_size * 0.5 + vec2 (spread);                  \n"\
+"  vec2 q = abs (p - frame_size * 0.5) -                              \n"\
+"           (half_size - vec2 (radius + spread));                      \n"\
+"                                                                      \n"\
+"  return length (max (q, vec2 (0.0))) +                              \n"\
+"         min (max (q.x, q.y), 0.0) - radius - spread;                \n"\
+"}                                                                     \n"\
+"                                                                      \n"\
+"float erf_approx (float x)                                            \n"\
+"{                                                                     \n"\
+"  float x_squared = x * x;                                            \n"\
+"  float a = 0.147;                                                    \n"\
+"  float value = 1.0 - exp (-x_squared *                              \n"\
+"                            (1.27323954 + a * x_squared) /             \n"\
+"                            (1.0 + a * x_squared));                    \n"\
+"                                                                      \n"\
+"  return sign (x) * sqrt (max (value, 0.0));                          \n"\
+"}                                                                     \n"\
+"                                                                      \n"\
+"float blurred_coverage (float distance, float blur_radius)            \n"\
+"{                                                                     \n"\
+"  float sigma = blur_radius * 0.5;                                    \n"\
+"  return 0.5 * (1.0 - erf_approx (distance /                          \n"\
+"                                   (1.41421356 * sigma)));             \n"\
+"}                                                                     \n"\
+"                                                                      \n"\
+"float hard_coverage (float distance)                                  \n"\
+"{                                                                     \n"\
+"  return 1.0 - smoothstep (-0.5 * geometry_scale,                     \n"\
+"                           0.5 * geometry_scale, distance);            \n"\
+"}                                                                     \n"
+
+#define ADWAITA_SHADOW_FRAGMENT_SHADER_CODE                            \
+"vec2 shadow_size = frame_size + vec2 (38.0 * geometry_scale);        \n"\
+"vec2 p = cogl_tex_coord0_in.xy * shadow_size -                       \n"\
+"         vec2 (19.0 * geometry_scale);                               \n"\
+"float base_distance = rounded_rect_distance (p, corner_radius, 0.0); \n"\
+"float base_coverage = hard_coverage (base_distance);                 \n"\
+"float first_alpha;                                                    \n"\
+"float second_alpha;                                                   \n"\
+"float edge_alpha;                                                     \n"\
+"                                                                      \n"\
+"if (focused > 0.5)                                                    \n"\
+"  {                                                                   \n"\
+"    first_alpha = 0.15 * blurred_coverage (                           \n"\
+"      rounded_rect_distance (p, corner_radius, 5.0 * geometry_scale),\n"\
+"      14.0 * geometry_scale);                                        \n"\
+"    second_alpha = 0.10 * blurred_coverage (                          \n"\
+"      rounded_rect_distance (p, corner_radius, 2.0 * geometry_scale),\n"\
+"      5.0 * geometry_scale);                                         \n"\
+"  }                                                                   \n"\
+"else                                                                  \n"\
+"  {                                                                   \n"\
+"    first_alpha = 0.0;                                                \n"\
+"    second_alpha = 0.08 * blurred_coverage (                          \n"\
+"      rounded_rect_distance (p, corner_radius, 5.0 * geometry_scale),\n"\
+"      10.0 * geometry_scale);                                        \n"\
+"  }                                                                   \n"\
+"                                                                      \n"\
+"edge_alpha = 0.05 * hard_coverage (                                   \n"\
+"  rounded_rect_distance (p, corner_radius, 1.0 * geometry_scale));   \n"\
+"float alpha = 1.0 - (1.0 - first_alpha) *                            \n"\
+"                    (1.0 - second_alpha) *                           \n"\
+"                    (1.0 - edge_alpha);                              \n"\
+"alpha *= (1.0 - base_coverage) * actor_opacity;                       \n"\
+"cogl_color_out = vec4 (0.0, 0.0, 0.0, alpha);                        \n"
+
